{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grok Link",
  "version": "0.3.0",
  "identifier": "com.ranzh.grok-link",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Grok Link",
        "width": 760,
        "height": 900,
        "resizable": true,
        "minWidth": 520,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
